<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.frontend_emp_pass_slip.controller.ReportsController"
      spacing="10"
      styleClass="screen">

    <padding>
        <Insets top="15" right="14" bottom="15" left="14"/>
    </padding>

    <!-- Title -->
    <Label text="REPORT GENERATION"
           styleClass="section-title"
           maxWidth="Infinity"/>

    <!-- Statistics Cards -->
    <HBox spacing="12">

        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="totalSlipsLabel"
                   text="0"
                   styleClass="stat-number"/>
            <Label text="Total Slips"/>
        </VBox>

        <VBox styleClass="stat-card"
              HBox.hgrow="ALWAYS"
              style="-fx-border-color: #ff4b21;">

            <Label fx:id="currentlyOutLabel"
                   text="0"
                   styleClass="stat-number danger-text"/>

            <Label text="Currently Out"/>
        </VBox>

        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">

            <Label fx:id="officialLabel"
                   text="0"
                   styleClass="stat-number"/>

            <Label text="Official"/>
        </VBox>

        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">

            <Label fx:id="avgDurationLabel"
                   text="0m"
                   styleClass="stat-number"/>

            <Label text="Avg Duration"/>
        </VBox>

    </HBox>

    <!-- Chart Panel -->
    <VBox styleClass="table-panel"
          prefHeight="320"
          VBox.vgrow="ALWAYS">

        <HBox spacing="8"
              alignment="CENTER_LEFT"
              styleClass="section-title">

            <Label fx:id="chartTitleLabel"
                   text="DAILY ACTIVITY - THIS WEEK"
                   style="-fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="dailyBtn"
                    text="Daily"
                    styleClass="primary-button"/>

            <Button fx:id="monthlyBtn"
                    text="Monthly"
                    styleClass="outline-button"/>

            <Button fx:id="printBtn"
                    text="Print"
                    styleClass="outline-button"/>

        </HBox>

        <BarChart fx:id="activityChart"
                  animated="true"
                  VBox.vgrow="ALWAYS">

            <xAxis>
                <CategoryAxis fx:id="dayAxis"
                              side="BOTTOM"/>
            </xAxis>

            <yAxis>
                <NumberAxis fx:id="valueAxis"
                            side="LEFT"
                            autoRanging="true"
                            minorTickCount="0"
                            tickUnit="1"/>
            </yAxis>

        </BarChart>

    </VBox>

    <!-- Department Table -->
    <TableView fx:id="reportsTable"
               prefHeight="190">

        <columns>

            <TableColumn fx:id="departmentCol"
                         text="Department"
                         prefWidth="250"/>

            <TableColumn fx:id="totalCol"
                         text="Total"
                         prefWidth="140"/>

            <TableColumn fx:id="officialCol"
                         text="Official"
                         prefWidth="180"/>

            <TableColumn fx:id="personalCol"
                         text="Personal"
                         prefWidth="180"/>

            <TableColumn fx:id="avgDurationCol"
                         text="Avg Duration"
                         prefWidth="260"/>

        </columns>

    </TableView>

</VBox>