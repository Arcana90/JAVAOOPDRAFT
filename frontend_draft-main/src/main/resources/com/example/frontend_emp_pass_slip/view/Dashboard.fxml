<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox styleClass="screen" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.frontend_emp_pass_slip.controller.DashboardController">
    <padding>
        <Insets top="15" right="14" bottom="15" left="14" xmlns="http://javafx.com/javafx/17"/>
    </padding>

    <HBox spacing="12">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="totalEmployeesLabel" text="0" styleClass="stat-number" />
            <Label text="Total Employees" styleClass="muted-text" />
        </VBox>

        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" style="-fx-border-color: #ff4b21;">
            <Label fx:id="activePassSlipsLabel" text="0" styleClass="stat-number danger-text" />
            <Label text="Active Pass Slips" styleClass="muted-text" />
        </VBox>

        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="todaysSlipsLabel" text="0" styleClass="stat-number" />
            <Label text="Today's Slips" styleClass="muted-text" />
        </VBox>

        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="totalRecordsLabel" text="0" styleClass="stat-number" />
            <Label text="Total Records" styleClass="muted-text" />
        </VBox>
    </HBox>

    <HBox spacing="10" prefHeight="218">
        <VBox styleClass="table-panel" HBox.hgrow="ALWAYS" spacing="8" style="-fx-border-color: #ff4b21;">
            <HBox styleClass="section-title">
                <Label text="CURRENTLY OUT" style="-fx-font-weight: bold;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="currentlyOutBadgeLabel" text="0" styleClass="badge" />
            </HBox>

            <VBox fx:id="currentlyOutList" spacing="8" style="-fx-padding: 8 12;" />
        </VBox>

        <VBox styleClass="table-panel" HBox.hgrow="ALWAYS" spacing="8">
            <Label text="RECENT ACTIVITY" styleClass="section-title" maxWidth="Infinity" />
            <VBox fx:id="recentActivityList" spacing="8" style="-fx-padding: 8 12;" />
        </VBox>
    </HBox>

    <VBox styleClass="table-panel">
        <Label text="QUICK STATS - TODAY" styleClass="section-title" maxWidth="Infinity" />

        <HBox>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-padding: 10;">
                <Label fx:id="officialBusinessLabel" text="0" styleClass="stat-number" />
                <Label text="Official Business" styleClass="muted-text" />
            </VBox>

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-padding: 10;">
                <Label fx:id="personalLabel" text="0" styleClass="stat-number" />
                <Label text="Personal" styleClass="muted-text" />
            </VBox>

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-padding: 10;">
                <Label fx:id="returnedTodayLabel" text="0" styleClass="stat-number" />
                <Label text="Returned" styleClass="muted-text" />
            </VBox>

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-padding: 10;">
                <Label fx:id="stillOutLabel" text="0" styleClass="stat-number danger-text" />
                <Label text="Still Out" styleClass="muted-text" />
            </VBox>
        </HBox>
    </VBox>
</VBox>