<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane styleClass="login-root" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.frontend_emp_pass_slip.controller.LoginController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>

    <VBox alignment="CENTER" spacing="12">
        <StackPane>
            <Circle radius="28" styleClass="logo-circle" />
            <Label text="LOGO" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #365675;" />
        </StackPane>
        <VBox alignment="CENTER" spacing="2">
            <Label text="PASS SLIP SYSTEM" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
            <Label text="Employee Pass Slip Issuance &amp; Monitoring" styleClass="muted-text" />
        </VBox>

        <VBox styleClass="login-card" spacing="8" prefWidth="252">
            <Label text="Username" style="-fx-font-weight: bold;" />
            <TextField fx:id="usernameField" promptText="Enter username" onAction="#login" />
            <Label text="Password" style="-fx-font-weight: bold;" />
            <PasswordField fx:id="passwordField" promptText="Enter password" onAction="#login" />
            <Hyperlink text="Forgot Password" />
            <Label fx:id="statusLabel" wrapText="true" style="-fx-text-fill: #ff4b21;" />
            <Button text="LOGIN" maxWidth="Infinity" onAction="#login" styleClass="primary-button" />
            <Separator />
            <Hyperlink text="- Terms and Conditions" />
            <Hyperlink text="- Privacy and Policy" />
        </VBox>
    </VBox>
</StackPane>
