<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox styleClass="screen" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.frontend_emp_pass_slip.controller.MonitoringController">
    <padding><Insets top="15" right="14" bottom="15" left="14" xmlns="http://javafx.com/javafx/17"/></padding>
    <VBox styleClass="table-panel">
        <Label text="MONITORING &amp; LOGS" styleClass="section-title" maxWidth="Infinity" />
        <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 8;">
            <TextField fx:id="searchField" promptText="Search name or slip no..." prefWidth="196" />
            <ComboBox fx:id="statusFilter" prefWidth="88" />
            <Button text="Export" onAction="#exportCsv" styleClass="outline-button" />
        </HBox>
        <TableView fx:id="monitoringTable" prefHeight="205">
            <columns>
                <TableColumn fx:id="slipNoColumn" text="Slip No." prefWidth="125" />
                <TableColumn fx:id="employeeIdColumn" text="Employee ID" prefWidth="115" />
                <TableColumn fx:id="nameColumn" text="Name" prefWidth="145" />
                <TableColumn fx:id="departmentColumn" text="Department" prefWidth="110" />
                <TableColumn fx:id="dateColumn" text="Date" prefWidth="110" />
                <TableColumn fx:id="timeOutColumn" text="Time Out" prefWidth="92" />
                <TableColumn fx:id="timeInColumn" text="Time In" prefWidth="80" />
                <TableColumn fx:id="durationColumn" text="Duration" prefWidth="90" />
                <TableColumn fx:id="typeColumn" text="Type" prefWidth="85" />
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="85" />
            </columns>
        </TableView>
        <Label fx:id="countLabel" style="-fx-padding: 8;" styleClass="muted-text" />
    </VBox>
</VBox>
