<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox styleClass="screen" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.frontend_emp_pass_slip.controller.PassSlipIssuanceController">
    <padding><Insets top="15" right="14" bottom="15" left="14" xmlns="http://javafx.com/javafx/17"/></padding>
    <Label text="ISSUE PASS SLIP" styleClass="section-title" maxWidth="Infinity" />
    <GridPane hgap="20" vgap="10" maxWidth="590">
        <columnConstraints>
            <ColumnConstraints percentWidth="50" />
            <ColumnConstraints percentWidth="50" />
        </columnConstraints>
        <Label text="Employee *" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <ComboBox fx:id="employeeComboBox" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2" />
        <Label text="Department" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <Label text="Position" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        <TextField fx:id="departmentField" editable="false" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="positionField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        <Label text="Supervisor" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <Label text="Type of Pass" GridPane.columnIndex="1" GridPane.rowIndex="4" />
        <TextField fx:id="supervisorField" editable="false" GridPane.columnIndex="0" GridPane.rowIndex="5" />
        <ComboBox fx:id="passTypeComboBox" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="5" />
        <Label text="Destination *" GridPane.columnIndex="0" GridPane.rowIndex="6" />
        <TextField fx:id="destinationField" promptText="Office, establishment, or address" GridPane.columnIndex="0" GridPane.rowIndex="7" GridPane.columnSpan="2" />
        <Label text="Reason / Nature of Pass *" GridPane.columnIndex="0" GridPane.rowIndex="8" />
        <TextArea fx:id="reasonTextArea" prefRowCount="3" promptText="Describe the reason for this pass slip..." GridPane.columnIndex="0" GridPane.rowIndex="9" GridPane.columnSpan="2" />
        <Label fx:id="timeOutLabel" maxWidth="Infinity" style="-fx-background-color: #e8f7ff; -fx-border-color: #7dbdff; -fx-padding: 8;" GridPane.columnIndex="0" GridPane.rowIndex="10" GridPane.columnSpan="2" />
        <Label fx:id="statusLabel" wrapText="true" GridPane.columnIndex="0" GridPane.rowIndex="11" GridPane.columnSpan="2" />
        <Button text="Issue Pass Slip" onAction="#issuePassSlip" styleClass="primary-button" GridPane.columnIndex="0" GridPane.rowIndex="12" />
    </GridPane>
</VBox>
