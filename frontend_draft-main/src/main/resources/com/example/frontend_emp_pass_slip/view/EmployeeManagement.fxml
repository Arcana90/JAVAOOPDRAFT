<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox styleClass="screen" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.frontend_emp_pass_slip.controller.EmployeeManagementController">
    <padding><Insets top="15" right="14" bottom="15" left="14" xmlns="http://javafx.com/javafx/17"/></padding>
    <Label text="EMPLOYEE RECORDS" styleClass="section-title" maxWidth="Infinity" />
    <HBox spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search by name or ID..." prefWidth="196" />
        <Button text="+ Add Employee" onAction="#addEmployee" styleClass="primary-button" />
        <Button text="Deactivate Selected" onAction="#deactivateSelectedEmployee" />
    </HBox>
    <TableView fx:id="employeeTable" prefHeight="260">
        <columns>
            <TableColumn fx:id="employeeIdColumn" text="Employee ID" prefWidth="115" />
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="145" />
            <TableColumn fx:id="departmentColumn" text="Department" prefWidth="160" />
            <TableColumn fx:id="positionColumn" text="Position" prefWidth="150" />
            <TableColumn fx:id="contactNumberColumn" text="Contact No." prefWidth="130" />
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="205" />
            <TableColumn fx:id="supervisorColumn" text="Supervisor" prefWidth="150" />
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="75" />
        </columns>
    </TableView>
    <Label fx:id="statusLabel" styleClass="muted-text" />
</VBox>
